#!/usr/bin/env sh
set -eu

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)
repo_root=$(CDPATH= cd "$script_dir/.." && pwd)
. "$script_dir/sandbox-gateway-token"

sandbox_gateway_token_load

local_cli="$repo_root/target/debug/sandbox-observability-cli"
release_cli="$repo_root/bin/sandbox-observability-cli-bin"
if [ -x "$release_cli" ]; then
    exec "$release_cli" "$@"
fi

if [ -x "$local_cli" ]; then
    exec "$local_cli" "$@"
fi

exec cargo run --quiet --manifest-path "$repo_root/Cargo.toml" -p sandbox-cli --features observability --bin sandbox-observability-cli -- "$@"
