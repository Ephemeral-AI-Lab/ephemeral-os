#!/bin/sh
set -eu

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)
repo_root=$(CDPATH= cd "$script_dir/.." && pwd)
. "$script_dir/sandbox-gateway-token"

export PATH="$repo_root/bin:$PATH"

config_yaml=${SANDBOX_GATEWAY_CONFIG_YAML:-$repo_root/config/prd.yml}
default_socket=${SANDBOX_GATEWAY_SOCKET:-127.0.0.1:7878}
pid_file_from_env=${SANDBOX_GATEWAY_PID_FILE:-}
pid_file=${pid_file_from_env:-/tmp/eos-gateway.pid}
socket_path=$default_socket
target_dir=${CARGO_TARGET_DIR:-$repo_root/target}
case "$target_dir" in
    /*) ;;
    *) target_dir=$(pwd)/$target_dir ;;
esac
gateway_bin=$target_dir/debug/sandbox-gateway
manager_cli_bin=$target_dir/debug/sandbox-manager-cli
runtime_cli_bin=$target_dir/debug/sandbox-runtime-cli
observability_cli_bin=$target_dir/debug/sandbox-observability-cli
xtask_bin=$target_dir/debug/xtask
release_gateway_bin=$repo_root/bin/sandbox-gateway-bin
release_manager_cli_bin=$repo_root/bin/sandbox-manager-cli-bin
release_runtime_cli_bin=$repo_root/bin/sandbox-runtime-cli-bin
release_observability_cli_bin=$repo_root/bin/sandbox-observability-cli-bin
rebuild_binary=0
show_help=0
pid_file_arg_seen=0
arg_count=$#
while [ "$arg_count" -gt 0 ]; do
    arg=$1
    shift
    arg_count=$((arg_count - 1))
    case "$arg" in
        --rebuild-binary) rebuild_binary=1 ;;
        -h|--help)
            show_help=1
            set -- "$@" "$arg"
            ;;
        *) set -- "$@" "$arg" ;;
    esac
done

set -- --backend docker --config-yaml "$config_yaml" "$@"

previous_flag=
for arg in "$@"; do
    if [ "$previous_flag" = "pid-file" ]; then
        pid_file=$arg
        previous_flag=
        continue
    fi
    if [ "$previous_flag" = "gateway-socket" ]; then
        socket_path=$arg
        previous_flag=
        continue
    fi

    case "$arg" in
        -h|--help)
            show_help=1
            ;;
        --pid-file)
            pid_file_arg_seen=1
            previous_flag=pid-file
            ;;
        --pid-file=*)
            pid_file_arg_seen=1
            pid_file=${arg#--pid-file=}
            ;;
        --gateway-socket)
            previous_flag=gateway-socket
            ;;
        --gateway-socket=*)
            socket_path=${arg#--gateway-socket=}
            ;;
    esac
done

if [ -n "$pid_file_from_env" ] && [ "$pid_file_arg_seen" -eq 0 ]; then
    set -- "$@" --pid-file "$pid_file"
fi

release_host_bins_available() {
    [ -x "$release_gateway_bin" ] &&
        [ -x "$release_manager_cli_bin" ] &&
        [ -x "$release_runtime_cli_bin" ] &&
        [ -x "$release_observability_cli_bin" ]
}

if [ "$rebuild_binary" -eq 0 ] && release_host_bins_available; then
    gateway_bin=$release_gateway_bin
    manager_cli_bin=$release_manager_cli_bin
    runtime_cli_bin=$release_runtime_cli_bin
    observability_cli_bin=$release_observability_cli_bin
    printf 'using packaged host binaries from %s/bin\n' "$repo_root"
elif [ "$rebuild_binary" -eq 1 ]; then
    printf 'cleaning host build profile\n'
    cargo clean --quiet --manifest-path "$repo_root/Cargo.toml" --profile dev
    printf 'building host binaries\n'
    cargo build --quiet --manifest-path "$repo_root/Cargo.toml" \
        -p sandbox-gateway --bin sandbox-gateway \
        -p xtask --bin xtask
    cargo build --quiet --manifest-path "$repo_root/Cargo.toml" \
        -p sandbox-cli --no-default-features --features manager --bin sandbox-manager-cli
    cargo build --quiet --manifest-path "$repo_root/Cargo.toml" \
        -p sandbox-cli --no-default-features --features runtime --bin sandbox-runtime-cli
    cargo build --quiet --manifest-path "$repo_root/Cargo.toml" \
        -p sandbox-cli --no-default-features --features observability --bin sandbox-observability-cli
else
    printf 'building host binaries\n'
    cargo build --quiet --manifest-path "$repo_root/Cargo.toml" \
        -p sandbox-gateway --bin sandbox-gateway \
        -p xtask --bin xtask
    cargo build --quiet --manifest-path "$repo_root/Cargo.toml" \
        -p sandbox-cli --no-default-features --features manager --bin sandbox-manager-cli
    cargo build --quiet --manifest-path "$repo_root/Cargo.toml" \
        -p sandbox-cli --no-default-features --features runtime --bin sandbox-runtime-cli
    cargo build --quiet --manifest-path "$repo_root/Cargo.toml" \
        -p sandbox-cli --no-default-features --features observability --bin sandbox-observability-cli
fi
for host_bin in "$gateway_bin" "$manager_cli_bin" "$runtime_cli_bin" "$observability_cli_bin" "$xtask_bin"; do
    if [ "$host_bin" = "$xtask_bin" ] && [ "$rebuild_binary" -eq 0 ] && release_host_bins_available; then
        continue
    fi
    if [ ! -x "$host_bin" ]; then
        printf 'built host binary not found at %s\n' "$host_bin" >&2
        exit 1
    fi
done

if [ "$show_help" -eq 0 ]; then
    daemon_artifact_rel=$(
        sed -n 's/^[[:space:]]*daemon_binary_path:[[:space:]]*//p' "$config_yaml" | sed -n '1p'
    )
    daemon_artifact_rel=${daemon_artifact_rel#\"}
    daemon_artifact_rel=${daemon_artifact_rel%\"}
    daemon_artifact_rel=${daemon_artifact_rel#\'}
    daemon_artifact_rel=${daemon_artifact_rel%\'}

    case "$daemon_artifact_rel" in
        '') printf 'daemon_binary_path not found in %s\n' "$config_yaml" >&2; exit 1 ;;
        /*) daemon_artifact=$daemon_artifact_rel ;;
        *) daemon_artifact=$repo_root/$daemon_artifact_rel ;;
    esac

    case "${daemon_artifact##*/}" in
        *-arm64) package_target=aarch64-unknown-linux-musl ;;
        *-amd64) package_target=x86_64-unknown-linux-musl ;;
        *) printf 'cannot infer package target from %s\n' "$daemon_artifact" >&2; exit 1 ;;
    esac

    needs_package=0
    if [ "$rebuild_binary" -eq 0 ] && [ ! -x "$daemon_artifact" ]; then
        needs_package=1
    elif [ "$rebuild_binary" -eq 0 ] && [ -f "$repo_root/Cargo.toml" ] && [ -d "$repo_root/crates" ]; then
        # Coarse source mtime check; use cargo metadata if false positives matter.
        newer_source=$(
            find \
                "$repo_root/Cargo.toml" \
                "$repo_root/Cargo.lock" \
                "$repo_root/.cargo/config.toml" \
                "$repo_root/crates/sandbox-daemon/Cargo.toml" \
                "$repo_root/crates/sandbox-daemon/src" \
                "$repo_root/crates/sandbox-config/Cargo.toml" \
                "$repo_root/crates/sandbox-config/src" \
                "$repo_root/crates/sandbox-operations/contract" \
                "$repo_root/crates/sandbox-operations/catalog" \
                "$repo_root/crates/sandbox-observability/telemetry" \
                "$repo_root/crates/sandbox-observability/query" \
                "$repo_root/crates/sandbox-protocol/Cargo.toml" \
                "$repo_root/crates/sandbox-protocol/src" \
                "$repo_root/crates/sandbox-runtime" \
                -type f \( -name '*.rs' -o -name 'Cargo.toml' -o -name 'Cargo.lock' \) \
                -newer "$daemon_artifact" \
                -print -quit
        )
        [ -z "$newer_source" ] || needs_package=1
    fi

    if [ "$rebuild_binary" -eq 1 ]; then
        package_profile=${SANDBOX_XTASK_PROFILE:-package-fast}
        printf 'cleaning daemon build profile for %s\n' "$package_target"
        cargo clean --quiet --manifest-path "$repo_root/Cargo.toml" \
            --target "$package_target" --profile "$package_profile"
    fi

    if [ "$rebuild_binary" -eq 1 ] || [ "$needs_package" -eq 1 ]; then
        if [ ! -x "$xtask_bin" ]; then
            printf 'xtask binary not found at %s; install from a complete release or build from source\n' "$xtask_bin" >&2
            exit 1
        fi
        "$xtask_bin" package --target "$package_target"
    fi
fi

if [ "$show_help" -eq 1 ]; then
    printf 'start-sandbox-docker-gateway options:\n'
    printf '  --rebuild-binary  clean and rebuild host binaries plus the configured sandbox-daemon target\n\n'
    exec "$gateway_bin" serve "$@"
fi

log_file=${SANDBOX_GATEWAY_LOG:-${pid_file%.*}.log}
if [ "$log_file" = "$pid_file" ]; then
    log_file=$pid_file.log
fi

stop_existing_gateway() {
    [ -f "$pid_file" ] || return 0

    old_pid=$(sed -n '1p' "$pid_file" 2>/dev/null || true)
    case "$old_pid" in
        ''|*[!0-9]*)
            rm -f "$pid_file"
            return 0
            ;;
    esac

    if ! kill -0 "$old_pid" 2>/dev/null; then
        rm -f "$pid_file" "$socket_path"
        return 0
    fi

    process_name=$(ps -p "$old_pid" -o comm= 2>/dev/null || true)
    case "$process_name" in
        *sandbox-gateway*) ;;
        *)
            printf 'stale pid file %s points at non-gateway process %s; not killing\n' "$pid_file" "$old_pid" >&2
            rm -f "$pid_file"
            return 0
            ;;
    esac

    printf 'stopping existing sandbox-gateway pid %s\n' "$old_pid"
    kill "$old_pid" 2>/dev/null || true

    count=0
    while kill -0 "$old_pid" 2>/dev/null && [ "$count" -lt 50 ]; do
        sleep 0.1
        count=$((count + 1))
    done

    if kill -0 "$old_pid" 2>/dev/null; then
        printf 'existing sandbox-gateway pid %s did not stop; killing forcefully\n' "$old_pid" >&2
        kill -KILL "$old_pid" 2>/dev/null || true
    fi

    rm -f "$pid_file" "$socket_path"
}

stop_existing_gateway

auth_token=${SANDBOX_GATEWAY_AUTH_TOKEN:-}
if [ -z "$auth_token" ]; then
    auth_token=$(sandbox_gateway_token_ensure)
else
    printf '%s\n' "$auth_token" | sandbox_gateway_token_write
fi
export SANDBOX_GATEWAY_AUTH_TOKEN="$auth_token"
token_file=$(sandbox_gateway_token_path)

mkdir -p "$(dirname "$pid_file")" "$(dirname "$log_file")"

if command -v python3 >/dev/null 2>&1; then
    launcher_pid=$(
        GATEWAY_BIN=$gateway_bin LOG_FILE=$log_file python3 - "$@" <<'PY'
import os
import subprocess
import sys

log = open(os.environ["LOG_FILE"], "ab", buffering=0)
process = subprocess.Popen(
    ["nohup", os.environ["GATEWAY_BIN"], "serve", *sys.argv[1:]],
    stdin=subprocess.DEVNULL,
    stdout=log,
    stderr=subprocess.STDOUT,
    start_new_session=True,
    close_fds=True,
)
print(process.pid)
PY
    )
else
    nohup "$gateway_bin" serve "$@" >>"$log_file" 2>&1 &
    launcher_pid=$!
fi

count=0
while [ "$count" -lt 20 ]; do
    if ! kill -0 "$launcher_pid" 2>/dev/null; then
        printf 'sandbox-gateway failed to stay running; see log: %s\n' "$log_file" >&2
        tail -20 "$log_file" >&2 2>/dev/null || true
        exit 1
    fi
    [ -f "$pid_file" ] && break
    sleep 0.1
    count=$((count + 1))
done

printf 'sandbox-gateway starting in background via launcher pid %s\n' "$launcher_pid"
printf 'pid file: %s\n' "$pid_file"
printf 'address: %s\n' "$socket_path"
printf 'auth token file: %s\n' "$token_file"
printf 'log: %s\n' "$log_file"
printf 'bin/sandbox-*-cli wrappers read this token automatically\n'
