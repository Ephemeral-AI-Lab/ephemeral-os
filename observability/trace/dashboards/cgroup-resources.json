{
  "uid": "sandbox-cgroup-resources",
  "title": "Sandbox Cgroup Resources",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["sandbox", "metrics", "cgroup"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "sandbox_id",
        "label": "Sandbox",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(sandbox_cgroup_cpu_percent, sandbox_id)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "CPU percent",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(sandbox_cgroup_cpu_percent{sandbox_id=~\"$sandbox_id\"}) by (sandbox_id, cgroup_target_kind, status)",
          "legendFormat": "{{sandbox_id}} {{cgroup_target_kind}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Memory current",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(sandbox_cgroup_memory_current_bytes{sandbox_id=~\"$sandbox_id\"}) by (sandbox_id, cgroup_target_kind, status)",
          "legendFormat": "{{sandbox_id}} {{cgroup_target_kind}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "title": "PIDs current",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(sandbox_cgroup_pids_current{sandbox_id=~\"$sandbox_id\"}) by (sandbox_id, cgroup_target_kind, status)",
          "legendFormat": "{{sandbox_id}} {{cgroup_target_kind}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
    },
    {
      "id": 4,
      "title": "Pressure avg10",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(sandbox_cgroup_pressure_some_avg10{sandbox_id=~\"$sandbox_id\"}) by (sandbox_id, cgroup_target_kind, resource_kind, status)",
          "legendFormat": "{{sandbox_id}} {{cgroup_target_kind}} {{resource_kind}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
    },
    {
      "id": 5,
      "title": "Disk upperdir bytes",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(sandbox_cgroup_disk_upperdir_bytes{sandbox_id=~\"$sandbox_id\"}) by (sandbox_id, cgroup_target_kind, status)",
          "legendFormat": "{{sandbox_id}} {{cgroup_target_kind}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "id": 6,
      "title": "Cgroup read errors",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sandbox_cgroup_read_errors_total{sandbox_id=~\"$sandbox_id\"}[5m])) by (sandbox_id, cgroup_target_kind, bounded_error_kind)",
          "legendFormat": "{{sandbox_id}} {{cgroup_target_kind}} {{bounded_error_kind}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ]
}
