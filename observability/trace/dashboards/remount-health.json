{
  "uid": "sandbox-remount-health",
  "title": "Sandbox Remount Health",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["sandbox", "metrics", "remount"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "sandbox_id",
        "label": "Sandbox",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(sandbox_workspace_phase_latency_ms_milliseconds_count, sandbox_id)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Remount failures",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(sandbox_remount_failures_total{sandbox_id=~\"$sandbox_id\"}) by (sandbox_id, bounded_reason)",
          "legendFormat": "{{sandbox_id}} {{bounded_reason}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Remount phase average latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (sandbox_id, status) (sandbox_workspace_phase_latency_ms_milliseconds_sum{sandbox_id=~\"$sandbox_id\", workspace_phase=\"remount_workspace\"}) / sum by (sandbox_id, status) (sandbox_workspace_phase_latency_ms_milliseconds_count{sandbox_id=~\"$sandbox_id\", workspace_phase=\"remount_workspace\"})",
          "legendFormat": "{{sandbox_id}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 }
    }
  ]
}
