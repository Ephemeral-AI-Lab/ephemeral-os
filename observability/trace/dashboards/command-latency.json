{
  "uid": "sandbox-command-latency",
  "title": "Sandbox Command Latency",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "tags": ["sandbox", "metrics", "commands"],
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "sandbox_id",
        "label": "Sandbox",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(sandbox_runtime_operation_latency_ms_milliseconds_count, sandbox_id)",
        "refresh": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Runtime operation average latency",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (sandbox_id, operation, status) (sandbox_runtime_operation_latency_ms_milliseconds_sum{sandbox_id=~\"$sandbox_id\", operation=~\"exec_command|write_command_stdin|read_command_lines\"}) / sum by (sandbox_id, operation, status) (sandbox_runtime_operation_latency_ms_milliseconds_count{sandbox_id=~\"$sandbox_id\", operation=~\"exec_command|write_command_stdin|read_command_lines\"})",
          "legendFormat": "{{sandbox_id}} {{operation}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Command operation rate by status",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(sandbox_runtime_operation_latency_ms_milliseconds_count{sandbox_id=~\"$sandbox_id\", operation=~\"exec_command|write_command_stdin|read_command_lines\"}[5m])) by (sandbox_id, operation, status)",
          "legendFormat": "{{sandbox_id}} {{operation}} {{status}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" },
        "overrides": []
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 10 }
    }
  ]
}
