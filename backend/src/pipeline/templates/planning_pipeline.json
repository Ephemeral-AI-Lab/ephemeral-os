{
  "pipeline_id": "planning-default",
  "name": "Codebase Planning Pipeline",
  "description": "Analyze → Explore → Synthesize → Plan Tasks",
  "version": 1,
  "steps": [
    {
      "name": "analyze",
      "agent": "planning-analyze",
      "description": "Partition codebase into exploration regions",
      "output_schema": {
        "type": "object",
        "properties": {
          "regions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "path": {"type": "string"},
                "focus": {"type": "string"},
                "priority": {"type": "string"}
              }
            }
          }
        }
      }
    },
    {
      "name": "explore",
      "agent": "planning-explore",
      "description": "Parallel exploration of regions",
      "input_deps": [{"step": "analyze", "keys": ["regions"]}]
    },
    {
      "name": "synthesize",
      "agent": "planning-synthesize",
      "description": "Merge exploration reports into unified codebase map",
      "input_deps": [{"step": "explore"}]
    },
    {
      "name": "plan_tasks",
      "agent": "planning-plan-tasks",
      "description": "Generate task DAG from synthesized understanding",
      "input_deps": [{"step": "synthesize"}],
      "posthook_agent": "output-formatter",
      "output_schema": {
        "type": "object",
        "properties": {
          "tasks": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "task_id": {"type": "string"},
                "description": {"type": "string"},
                "agent_name": {"type": "string"},
                "depends_on": {"type": "array", "items": {"type": "string"}}
              }
            }
          }
        }
      }
    }
  ],
  "tags": ["planning", "coordination"]
}
