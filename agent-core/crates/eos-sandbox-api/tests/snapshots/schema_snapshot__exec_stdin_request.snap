---
source: crates/eos-sandbox-api/tests/schema_snapshot.rs
expression: schema
---
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecStdinRequest",
  "description": "Write characters to an open command session through `api.v1.write_stdin`.",
  "type": "object",
  "required": [
    "caller_id",
    "chars",
    "command_session_id"
  ],
  "properties": {
    "caller_id": {
      "description": "Opaque sandbox caller identity for audit and routing.",
      "type": "string"
    },
    "chars": {
      "description": "Characters (stdin) to write.",
      "type": "string"
    },
    "command_session_id": {
      "description": "Target command-session id.",
      "type": "string"
    },
    "description": {
      "description": "Human-readable operation description; falls back via [`Self::description_or`].",
      "default": "",
      "type": "string"
    },
    "invocation_id": {
      "description": "Optional in-flight correlation id, reused by the transport when present.",
      "type": [
        "string",
        "null"
      ]
    },
    "max_output_tokens": {
      "description": "Cap on output tokens returned.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0.0
    },
    "terminate": {
      "description": "Tear the session down (SIGTERM→SIGKILL) after writing — the explicit teardown channel, decoupled from `\\x03`/SIGINT (sense-2 D7).",
      "type": "boolean"
    },
    "yield_time_ms": {
      "description": "Yield window in milliseconds before returning partial output.",
      "type": [
        "integer",
        "null"
      ],
      "format": "uint32",
      "minimum": 0.0
    }
  }
}
