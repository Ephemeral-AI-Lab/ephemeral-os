---
source: crates/eos-state/src/../tests/unit/mod.rs
assertion_line: 139
expression: schemas
---
{
  "ExecutionTaskOutcome": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ExecutionTaskOutcome",
    "description": "One generator/reducer task's terminal execution evidence (Python `ExecutionTaskOutcome`). Bounded to a single persisted task.",
    "type": "object",
    "required": [
      "outcome",
      "role",
      "status",
      "task_id"
    ],
    "properties": {
      "outcome": {
        "description": "Free-text outcome summary.",
        "type": "string"
      },
      "role": {
        "description": "The execution role that produced this outcome.",
        "allOf": [
          {
            "$ref": "#/definitions/ExecutionRole"
          }
        ]
      },
      "status": {
        "description": "Whether the task succeeded or failed.",
        "allOf": [
          {
            "$ref": "#/definitions/TaskOutcomeStatus"
          }
        ]
      },
      "task_id": {
        "description": "The task that produced this outcome.",
        "type": "string"
      }
    },
    "definitions": {
      "ExecutionRole": {
        "description": "The execution role an outcome belongs to (Python `ExecutionRole`). Only `generator`/`reducer` execution evidence ever appears in outcomes.",
        "oneOf": [
          {
            "description": "A generator (execution) task.",
            "type": "string",
            "enum": [
              "generator"
            ]
          },
          {
            "description": "A reducer task (the attempt's exit gate).",
            "type": "string",
            "enum": [
              "reducer"
            ]
          }
        ]
      },
      "TaskOutcomeStatus": {
        "description": "Binary status of one execution outcome (Python `TaskOutcomeStatus`).",
        "oneOf": [
          {
            "description": "The task completed successfully.",
            "type": "string",
            "enum": [
              "success"
            ]
          },
          {
            "description": "The task failed.",
            "type": "string",
            "enum": [
              "failed"
            ]
          }
        ]
      }
    }
  },
  "PlannerSubmission": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "PlannerSubmission",
    "description": "Validated planner submission from a full or partial plan tool (Python `PlannerSubmission`).",
    "type": "object",
    "required": [
      "attempt_id",
      "plan"
    ],
    "properties": {
      "attempt_id": {
        "description": "Owning attempt.",
        "type": "string"
      },
      "plan": {
        "description": "Resolved plan authored by the planner.",
        "allOf": [
          {
            "$ref": "#/definitions/MaterializedPlan"
          }
        ]
      }
    },
    "definitions": {
      "MaterializedPlan": {
        "description": "Resolved persisted task ids for a planner-authored attempt plan.",
        "type": "object",
        "required": [
          "disposition",
          "generator_task_ids",
          "planner_task_id",
          "reducer_task_ids"
        ],
        "properties": {
          "disposition": {
            "description": "Whether the plan completes or defers.",
            "allOf": [
              {
                "$ref": "#/definitions/PlanDisposition"
              }
            ]
          },
          "generator_task_ids": {
            "description": "Persisted generator task ids.",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "planner_task_id": {
            "description": "Planner task that authored the plan.",
            "type": "string"
          },
          "reducer_task_ids": {
            "description": "Persisted reducer task ids.",
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "PlanDisposition": {
        "description": "Planner disposition after the current iteration's reducers complete.",
        "oneOf": [
          {
            "description": "The plan covers the current iteration goal.",
            "type": "string",
            "enum": [
              "complete"
            ]
          },
          {
            "description": "The plan intentionally defers remaining current-iteration items.",
            "type": "object",
            "required": [
              "defer"
            ],
            "properties": {
              "defer": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "PlannerFailureSubmission": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "PlannerFailureSubmission",
    "description": "Runtime-synthesized planner failure (Python `PlannerFailureSubmission`).",
    "type": "object",
    "required": [
      "attempt_id",
      "fail_reason",
      "planner_task_id"
    ],
    "properties": {
      "attempt_id": {
        "description": "Owning attempt.",
        "type": "string"
      },
      "fail_reason": {
        "description": "The planner failure reason.",
        "allOf": [
          {
            "$ref": "#/definitions/PlannerFailReason"
          }
        ]
      },
      "planner_task_id": {
        "description": "The planner task that failed.",
        "type": "string"
      }
    },
    "definitions": {
      "PlannerFailReason": {
        "description": "Why a planner submission failed (Python `Literal[\"run_exhausted\"]`). Distinct from `AttemptFailReason` (spec §6.10).",
        "oneOf": [
          {
            "description": "The attempt's run budget was exhausted.",
            "type": "string",
            "enum": [
              "run_exhausted"
            ]
          }
        ]
      }
    }
  },
  "GeneratorSubmission": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "GeneratorSubmission",
    "description": "Validated terminal outcome for one generator task (Python `GeneratorSubmission`).",
    "type": "object",
    "required": [
      "attempt_id",
      "outcome",
      "status",
      "task_id",
      "terminal_tool_result"
    ],
    "properties": {
      "attempt_id": {
        "description": "Owning attempt.",
        "type": "string"
      },
      "outcome": {
        "description": "Free-text outcome summary.",
        "type": "string"
      },
      "status": {
        "description": "Success or failure.",
        "allOf": [
          {
            "$ref": "#/definitions/TaskOutcomeStatus"
          }
        ]
      },
      "task_id": {
        "description": "The generator task.",
        "type": "string"
      },
      "terminal_tool_result": {
        "description": "Flattened terminal tool result (always present on a terminal submit).",
        "type": "object",
        "additionalProperties": true
      }
    },
    "definitions": {
      "TaskOutcomeStatus": {
        "description": "Binary status of one execution outcome (Python `TaskOutcomeStatus`).",
        "oneOf": [
          {
            "description": "The task completed successfully.",
            "type": "string",
            "enum": [
              "success"
            ]
          },
          {
            "description": "The task failed.",
            "type": "string",
            "enum": [
              "failed"
            ]
          }
        ]
      }
    }
  },
  "ReducerSubmission": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ReducerSubmission",
    "description": "Validated terminal outcome for one reducer task (Python `ReducerSubmission`).",
    "type": "object",
    "required": [
      "attempt_id",
      "outcome",
      "status",
      "task_id",
      "terminal_tool_result"
    ],
    "properties": {
      "attempt_id": {
        "description": "Owning attempt.",
        "type": "string"
      },
      "outcome": {
        "description": "Free-text outcome summary.",
        "type": "string"
      },
      "status": {
        "description": "Success or failure.",
        "allOf": [
          {
            "$ref": "#/definitions/TaskOutcomeStatus"
          }
        ]
      },
      "task_id": {
        "description": "The reducer task.",
        "type": "string"
      },
      "terminal_tool_result": {
        "description": "Flattened terminal tool result (always present on a terminal submit).",
        "type": "object",
        "additionalProperties": true
      }
    },
    "definitions": {
      "TaskOutcomeStatus": {
        "description": "Binary status of one execution outcome (Python `TaskOutcomeStatus`).",
        "oneOf": [
          {
            "description": "The task completed successfully.",
            "type": "string",
            "enum": [
              "success"
            ]
          },
          {
            "description": "The task failed.",
            "type": "string",
            "enum": [
              "failed"
            ]
          }
        ]
      }
    }
  }
}
