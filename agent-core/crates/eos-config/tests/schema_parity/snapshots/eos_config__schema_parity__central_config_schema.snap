---
source: crates/eos-config/src/lib.rs
expression: rust
---
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CentralConfig",
  "definitions": {
    "AttemptConfig": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "max_concurrent_task_runs"
      ],
      "properties": {
        "max_concurrent_task_runs": {
          "type": "integer"
        }
      }
    },
    "DatabaseConfig": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "busy_timeout_ms",
        "foreign_keys",
        "pool_size",
        "url",
        "wal"
      ],
      "properties": {
        "busy_timeout_ms": {
          "type": "integer"
        },
        "foreign_keys": {
          "type": "boolean"
        },
        "pool_size": {
          "type": "integer"
        },
        "url": {
          "type": "string"
        },
        "wal": {
          "type": "boolean"
        }
      }
    },
    "ProvidersConfig": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "retry"
      ],
      "properties": {
        "retry": {
          "allOf": [
            {
              "$ref": "#/definitions/RetryConfig"
            }
          ]
        }
      }
    },
    "RetryConfig": {
      "additionalProperties": false,
      "type": "object",
      "required": [
        "base_delay_s",
        "max_delay_s",
        "max_retries",
        "status_codes"
      ],
      "properties": {
        "base_delay_s": {
          "format": "double",
          "type": "number"
        },
        "max_delay_s": {
          "format": "double",
          "type": "number"
        },
        "max_retries": {
          "type": "integer"
        },
        "status_codes": {
          "uniqueItems": true,
          "type": "array",
          "items": {
            "type": "integer"
          }
        }
      }
    }
  },
  "type": "object",
  "required": [
    "attempt",
    "database",
    "providers"
  ],
  "properties": {
    "attempt": {
      "allOf": [
        {
          "$ref": "#/definitions/AttemptConfig"
        }
      ]
    },
    "database": {
      "allOf": [
        {
          "$ref": "#/definitions/DatabaseConfig"
        }
      ]
    },
    "providers": {
      "allOf": [
        {
          "$ref": "#/definitions/ProvidersConfig"
        }
      ]
    }
  },
  "additionalProperties": false
}
