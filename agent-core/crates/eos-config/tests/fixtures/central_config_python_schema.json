{
  "$defs": {
    "AuditWarningsConfig": {
      "additionalProperties": false,
      "description": "Tunable thresholds for \u00a713 warnings (V3 Phase 3 deferral D6).\n\nOperators can adjust the \u00a713 thresholds per-environment without\ncode changes (e.g. memory peaks differ between live-e2e fixtures\nand capacity runs).",
      "properties": {
        "memory_peak_warn_bytes": {
          "default": 4294967296,
          "exclusiveMinimum": 0,
          "title": "Memory Peak Warn Bytes",
          "type": "integer"
        }
      },
      "title": "AuditWarningsConfig",
      "type": "object"
    },
    "DaemonAuditPullConfig": {
      "additionalProperties": false,
      "description": "Daemon audit pull runtime toggle (V3 Phase 3 \u00a7Default-on rollout).\n\n``enabled`` defaults to ``True`` once the 4 release gates pass on the\nheavy live-e2e fixture (see\n``docs/daemon-audit-pull-consolidation-v3/phase-3-report-and-release-gates.md``).\nOperators can opt out via ``EOS__RUNNER__DAEMON_AUDIT_PULL__ENABLED=false``\nor the shorter ``EOS_DAEMON_AUDIT_PULL_ENABLED=false`` env binding\nconsumed by :mod:`test_runner.audit.recorder`.\n\n``floor_ms`` mirrors ``EOS_DAEMON_AUDIT_PULL_FLOOR_MS``; ``stream_fallback``\nmirrors ``EOS_AUDIT_STREAM_FALLBACK``. Env vars retain precedence when\nexplicitly set (operators may still override per-shell).",
      "properties": {
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "floor_ms": {
          "default": 100,
          "exclusiveMinimum": 0,
          "title": "Floor Ms",
          "type": "integer"
        },
        "stream_fallback": {
          "default": true,
          "title": "Stream Fallback",
          "type": "boolean"
        }
      },
      "title": "DaemonAuditPullConfig",
      "type": "object"
    },
    "DatabaseConfig": {
      "additionalProperties": false,
      "description": "Database configuration.\n\nSQLite is the local/default runtime database. PostgreSQL remains available\nthrough an explicit process environment override.",
      "properties": {
        "url": {
          "default": "sqlite:///./.ephemeralos/ephemeralos.db",
          "title": "Url",
          "type": "string"
        },
        "pool_pre_ping": {
          "default": true,
          "title": "Pool Pre Ping",
          "type": "boolean"
        },
        "pool_size": {
          "default": 5,
          "minimum": 1,
          "title": "Pool Size",
          "type": "integer"
        },
        "max_overflow": {
          "default": 10,
          "minimum": 0,
          "title": "Max Overflow",
          "type": "integer"
        },
        "echo": {
          "default": false,
          "title": "Echo",
          "type": "boolean"
        }
      },
      "title": "DatabaseConfig",
      "type": "object"
    },
    "DaytonaConfig": {
      "additionalProperties": false,
      "description": "Daytona-provider settings and env-sourced credentials.",
      "properties": {
        "api_key": {
          "default": "",
          "title": "Api Key",
          "type": "string"
        },
        "api_url": {
          "default": "",
          "title": "Api Url",
          "type": "string"
        },
        "target": {
          "default": "",
          "title": "Target",
          "type": "string"
        },
        "tcp_host": {
          "default": "",
          "title": "Tcp Host",
          "type": "string"
        },
        "tcp_port": {
          "anyOf": [
            {
              "maximum": 65535,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tcp Port"
        },
        "default_image": {
          "default": "",
          "title": "Default Image",
          "type": "string"
        },
        "default_snapshot": {
          "default": "",
          "title": "Default Snapshot",
          "type": "string"
        }
      },
      "title": "DaytonaConfig",
      "type": "object"
    },
    "DockerConfig": {
      "additionalProperties": false,
      "description": "Docker-provider settings.",
      "properties": {
        "daemon_tcp": {
          "default": true,
          "title": "Daemon Tcp",
          "type": "boolean"
        },
        "privileged": {
          "default": false,
          "title": "Privileged",
          "type": "boolean"
        },
        "no_privilege": {
          "default": false,
          "title": "No Privilege",
          "type": "boolean"
        },
        "default_snapshot": {
          "default": "",
          "title": "Default Snapshot",
          "type": "string"
        }
      },
      "title": "DockerConfig",
      "type": "object"
    },
    "EngineConfig": {
      "additionalProperties": false,
      "description": "Engine-wide agent-loop tuning.",
      "properties": {},
      "title": "EngineConfig",
      "type": "object"
    },
    "LiveE2EConfig": {
      "additionalProperties": false,
      "description": "Live/e2e runner gates.",
      "properties": {
        "heavy_enabled": {
          "default": false,
          "title": "Heavy Enabled",
          "type": "boolean"
        },
        "capacity_enabled": {
          "default": false,
          "title": "Capacity Enabled",
          "type": "boolean"
        },
        "concurrent_sandbox_runners": {
          "default": 3,
          "minimum": 0,
          "title": "Concurrent Sandbox Runners",
          "type": "integer"
        },
        "real_agent_max_duration_s": {
          "default": 1800.0,
          "exclusiveMinimum": 0,
          "title": "Real Agent Max Duration S",
          "type": "number"
        }
      },
      "title": "LiveE2EConfig",
      "type": "object"
    },
    "MinimaxConfig": {
      "additionalProperties": false,
      "description": "Minimax provider routing config.",
      "properties": {
        "base_url": {
          "default": "",
          "title": "Base Url",
          "type": "string"
        },
        "model": {
          "default": "",
          "title": "Model",
          "type": "string"
        }
      },
      "title": "MinimaxConfig",
      "type": "object"
    },
    "ProvidersConfig": {
      "additionalProperties": false,
      "description": "Provider-level runtime configuration.",
      "properties": {
        "retry": {
          "$ref": "#/$defs/RetryConfig"
        },
        "minimax": {
          "$ref": "#/$defs/MinimaxConfig"
        }
      },
      "title": "ProvidersConfig",
      "type": "object"
    },
    "RetryConfig": {
      "additionalProperties": false,
      "description": "Provider retry policy.",
      "properties": {
        "max_retries": {
          "default": 3,
          "minimum": 0,
          "title": "Max Retries",
          "type": "integer"
        },
        "base_delay_s": {
          "default": 1.0,
          "minimum": 0,
          "title": "Base Delay S",
          "type": "number"
        },
        "max_delay_s": {
          "default": 30.0,
          "minimum": 0,
          "title": "Max Delay S",
          "type": "number"
        },
        "status_codes": {
          "default": [
            529,
            500,
            502,
            503,
            429
          ],
          "items": {
            "type": "integer"
          },
          "title": "Status Codes",
          "type": "array",
          "uniqueItems": true
        }
      },
      "title": "RetryConfig",
      "type": "object"
    },
    "RunnerConfig": {
      "additionalProperties": false,
      "description": "Test-runner defaults.",
      "properties": {
        "audit_dir": {
          "default": ".sweevo_runs",
          "format": "path",
          "title": "Audit Dir",
          "type": "string"
        },
        "run_label": {
          "default": "test_runner",
          "title": "Run Label",
          "type": "string"
        },
        "live_e2e": {
          "$ref": "#/$defs/LiveE2EConfig"
        },
        "sandbox_reuse_mode": {
          "default": "fresh",
          "enum": [
            "fresh",
            "reuse",
            "force_fresh"
          ],
          "title": "Sandbox Reuse Mode",
          "type": "string"
        },
        "sandbox_quota": {
          "default": 3,
          "minimum": 0,
          "title": "Sandbox Quota",
          "type": "integer"
        },
        "daemon_audit_pull": {
          "$ref": "#/$defs/DaemonAuditPullConfig"
        },
        "audit_warnings": {
          "$ref": "#/$defs/AuditWarningsConfig"
        }
      },
      "title": "RunnerConfig",
      "type": "object"
    },
    "SandboxConfig": {
      "additionalProperties": false,
      "description": "Sandbox provider defaults and provider-specific config.",
      "properties": {
        "default_provider": {
          "default": "docker",
          "enum": [
            "docker",
            "daytona"
          ],
          "title": "Default Provider",
          "type": "string"
        },
        "timeout_s": {
          "default": 300.0,
          "exclusiveMinimum": 0,
          "title": "Timeout S",
          "type": "number"
        },
        "runtime_client_timeout_s": {
          "default": 600.0,
          "exclusiveMinimum": 0,
          "title": "Runtime Client Timeout S",
          "type": "number"
        },
        "docker": {
          "$ref": "#/$defs/DockerConfig"
        },
        "daytona": {
          "$ref": "#/$defs/DaytonaConfig"
        }
      },
      "title": "SandboxConfig",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Composition root for all runtime-tunable EphemeralOS config.",
  "properties": {
    "database": {
      "$ref": "#/$defs/DatabaseConfig"
    },
    "sandbox": {
      "$ref": "#/$defs/SandboxConfig"
    },
    "providers": {
      "$ref": "#/$defs/ProvidersConfig"
    },
    "runner": {
      "$ref": "#/$defs/RunnerConfig"
    },
    "engine": {
      "$ref": "#/$defs/EngineConfig"
    }
  },
  "title": "CentralConfig",
  "type": "object"
}
